# Configuration for the Workflow

# Directory to monitor
MONITOR_DIR="/var/sftp/data"

# Base output directory path
BASE_OUTPUT_DIR="/var/sftp/output"

# Base queue directory path
BASE_QUEUE_DIR="/var/sftp/queue"

# Base log directory path
BASE_LOG_DIR="/var/sftp/log"

# temp directory path
BASE_TEMP_DIR="/var/tmp"

# AzCopy SP Credentials
AZCOPY_SP_CREDENTIALS="/etc/azcopy_sp_env.sh"

# Vault Credentials
KMS_CONFIDENTIAL_FPE_PATH="/etc/vault/kms_confidential_fpe.json"

# Processing script
PROCESSING_SCRIPT="${BASE_APP_DIR}/bin/file_processing.sh"

# Input CSV file config
INPUT_FILE_CONFIG="${BASE_APP_DIR}/config/file_ctrt_col.json"

# Mapping csv to parquet incremental spark job script
MAPPING_SCRIPT="${BASE_APP_DIR}/python/mapping_csv_to_parquet_incremental.py"

# Path for mapping table parquet output data
MAPPING_TABLE_PATH="${BASE_OUTPUT_DIR}/contract_uid_mapping_table/"

# Credit card numbers encoding spark job script
CC_ENCODE_SCRIPT="${BASE_APP_DIR}/python/cc_encode.py"

# Webhook URL for notifications (Power Automate)
WEBHOOK_URL="https://prod-03.japaneast.logic.azure.com:443/workflows/4e7aea8881684863a7449c9694ebb70b/triggers/manual/paths/invoke?api-version=2016-06-01&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=I1xgnyuwYyez-__J_Li-qnL-wTmPZEWRS-7_Gx8MISw"

# Azure Landing Storage Account
AZURE_BLOB_STORAGE_ACCOUNT="carddatabrickslanding"

# Spark configurations
SPARK_CONF="--master local[*] --conf spark.driver.memory=76g --conf spark.driver.memoryOverhead=4g --conf spark.driver.maxResultSize=4g --conf spark.sql.shuffle.spill=true --conf spark.local.dir=/var/tmp/ --conf spark.log.level=ERROR --conf spark.driver.extraJavaOptions=-Xss128m --conf spark.executor.extraJavaOptions=-Xss128m --conf spark.serializer=org.apache.spark.serializer.KryoSerializer"
